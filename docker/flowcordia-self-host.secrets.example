# Copy this file outside the repository, replace every placeholder, then run:
#   chmod 600 /absolute/path/deployment.secrets
# The validator rejects group/world-readable files and keys duplicated in config.

SESSION_SECRET=replace-with-at-least-32-random-characters
MAGIC_LINK_SECRET=replace-with-at-least-32-random-characters
ENCRYPTION_KEY=replace-with-32-hex-characters

# Independent control-plane credentials. Generate a different random value for each.
PROVIDER_SECRET=replace-with-at-least-32-random-characters
COORDINATOR_SECRET=replace-with-at-least-32-random-characters
MANAGED_WORKER_SECRET=replace-with-at-least-32-random-characters

DATABASE_URL=postgresql://flowcordia:replace-password@postgres.example.internal:5432/flowcordia?schema=public&sslmode=require
DIRECT_URL=postgresql://flowcordia_migrator:replace-password@postgres.example.internal:5432/flowcordia?schema=public&sslmode=require

CLICKHOUSE_URL=https://default:replace-password@clickhouse.example.internal:8443/default
RUN_REPLICATION_CLICKHOUSE_URL=https://default:replace-password@clickhouse.example.internal:8443/default

OBJECT_STORE_ACCESS_KEY_ID=replace-with-object-store-access-key
OBJECT_STORE_SECRET_ACCESS_KEY=replace-with-object-store-secret-key

GITHUB_APP_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nreplace-with-pem-body\n-----END PRIVATE KEY-----
GITHUB_APP_WEBHOOK_SECRET=replace-with-at-least-32-random-characters
FLOWCORDIA_PROPOSAL_EVENT_SECRET=replace-with-at-least-32-random-characters

# Resend example. Remove this key when using another supported transport.
RESEND_API_KEY=replace-with-resend-api-key

# SMTP alternative. Set EMAIL_TRANSPORT=smtp in deployment.env and remove the
# Resend key when using this block.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=flowcordia
# SMTP_PASSWORD=replace-with-smtp-password

# Optional external Redis authentication supported by the inherited runtime.
# REDIS_PASSWORD=replace-with-redis-password
