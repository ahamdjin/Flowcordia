# Copy this file outside the repository, replace every placeholder, and pass the
# absolute path through `docker compose --env-file`. Keep secrets in the separate
# protected secrets file; duplicate keys are rejected by the validator.

# Host-side deployment files
FLOWCORDIA_CONFIG_FILE=/opt/flowcordia/deployment.env
FLOWCORDIA_SECRETS_FILE=/opt/flowcordia/deployment.secrets
FLOWCORDIA_RELEASE_MANIFEST_FILE=/opt/flowcordia/releases/flowcordia-0.1.0-rc.1.json
FLOWCORDIA_MIGRATION_STATE_DIR=/var/lib/flowcordia/migrations
FLOWCORDIA_DIAGNOSTICS_STATE_DIR=/var/lib/flowcordia/diagnostics

# Immutable release identity copied from the protected publication artifact
FLOWCORDIA_IMAGE_REFERENCE=ghcr.io/owner/flowcordia@sha256:<64-lowercase-hex>
FLOWCORDIA_IMAGE_DIGEST=<64-lowercase-hex-without-sha256-prefix>
FLOWCORDIA_APPLICATION_COMMIT_SHA=<40-lowercase-hex>
FLOWCORDIA_RELEASE_MANIFEST_SHA256=<64-lowercase-hex>
FLOWCORDIA_RELEASE_RUNTIME_REQUIRED=1
FLOWCORDIA_MIGRATION_CONFIRM=flowcordia-0.1.0-rc.1

# Initial supported single-host topology. Values other than one are blocked.
FLOWCORDIA_WEB_REPLICAS=1
FLOWCORDIA_OPERATIONS_REPLICAS=1
FLOWCORDIA_HTTP_BIND=127.0.0.1
FLOWCORDIA_HTTP_PORT=3030
NODE_MAX_OLD_SPACE_SIZE=4096

# Application profile and public origins
APP_ENV=production
NODE_ENV=production
TZ=UTC
APP_ORIGIN=https://flowcordia.example.com
LOGIN_ORIGIN=https://flowcordia.example.com
FLOWCORDIA_STUDIO_ENABLED=0

# Every long-running application replica must leave migrations to `migrate`.
SKIP_POSTGRES_MIGRATIONS=1
SKIP_DASHBOARD_AGENT_MIGRATIONS=1
SKIP_CLICKHOUSE_MIGRATIONS=1

# External PostgreSQL, Redis, ClickHouse, and Electric identities
DATABASE_HOST=postgres.example.internal:5432
REDIS_HOST=redis.example.internal
REDIS_PORT=6379
REDIS_TLS_DISABLED=false
ELECTRIC_ORIGIN=https://electric.example.internal
RUN_REPLICATION_ENABLED=1
EVENT_REPOSITORY_DEFAULT_STORE=clickhouse_v2

# S3-compatible object store. Credentials belong in deployment.secrets.
OBJECT_STORE_BASE_URL=https://s3.example.com
OBJECT_STORE_BUCKET=flowcordia-packets
OBJECT_STORE_REGION=us-east-1
OBJECT_STORE_SERVICE=s3
OBJECT_STORE_DEFAULT_PROTOCOL=s3
# Set only for a provider that requires path-style bucket addressing.
# OBJECT_STORE_FORCE_PATH_STYLE=true

# Production email transport. Provider credentials belong in deployment.secrets.
EMAIL_TRANSPORT=resend
FROM_EMAIL=Flowcordia <no-reply@example.com>
REPLY_TO_EMAIL=support@example.com

# Installation-scoped GitHub App. Private key and webhook secret are protected.
GITHUB_APP_ENABLED=1
GITHUB_APP_ID=123456
GITHUB_APP_SLUG=flowcordia-example

# Dedicated proposal/index operations worker
FLOWCORDIA_PROPOSAL_EVENT_URL=https://flowcordia.example.com/api/flowcordia/proposal-events
FLOWCORDIA_PROPOSAL_WORKER_POLL_INTERVAL_MS=5000
FLOWCORDIA_PROPOSAL_WORKER_SHUTDOWN_GRACE_MS=30000
FLOWCORDIA_PROPOSAL_EVENT_TIMEOUT_MS=5000
FLOWCORDIA_PROPOSAL_OUTBOX_BATCH_SIZE=10
FLOWCORDIA_PROPOSAL_OUTBOX_LEASE_MS=60000
FLOWCORDIA_PROPOSAL_RECONCILIATION_BATCH_SIZE=5
FLOWCORDIA_PROPOSAL_RECONCILIATION_LEASE_MS=120000
FLOWCORDIA_PROPOSAL_RECONCILIATION_STALE_MS=300000
FLOWCORDIA_PROPOSAL_RECONCILIATION_REFRESH_MS=900000
FLOWCORDIA_PROPOSAL_GITHUB_TIMEOUT_MS=15000
