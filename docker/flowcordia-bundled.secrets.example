# Store outside the repository with mode 0600.
# Prefer generate-flowcordia-bundled-secrets.sh instead of hand-writing values.

SESSION_SECRET=<at-least-32-random-characters>
MAGIC_LINK_SECRET=<at-least-32-random-characters>
ENCRYPTION_KEY=<exactly-32-random-hex-characters>
MANAGED_WORKER_SECRET=<at-least-32-random-characters>

FLOWCORDIA_POSTGRES_PASSWORD=<random-postgres-password>
DATABASE_URL=postgresql://flowcordia:<same-postgres-password>@postgres:5432/flowcordia?schema=public&sslmode=disable
DIRECT_URL=postgresql://flowcordia:<same-postgres-password>@postgres:5432/flowcordia?schema=public&sslmode=disable

FLOWCORDIA_REDIS_PASSWORD=<random-redis-password>
REDIS_PASSWORD=<same-redis-password>

FLOWCORDIA_CLICKHOUSE_USER=default
FLOWCORDIA_CLICKHOUSE_PASSWORD=<random-clickhouse-password>
CLICKHOUSE_URL=http://default:<same-clickhouse-password>@clickhouse:8123/default?secure=false
RUN_REPLICATION_CLICKHOUSE_URL=http://default:<same-clickhouse-password>@clickhouse:8123/default

FLOWCORDIA_MINIO_ACCESS_KEY_ID=<random-minio-access-key>
FLOWCORDIA_MINIO_SECRET_ACCESS_KEY=<random-minio-secret-key>
OBJECT_STORE_ACCESS_KEY_ID=<same-minio-access-key>
OBJECT_STORE_SECRET_ACCESS_KEY=<same-minio-secret-key>
OBJECT_STORE_S3_ACCESS_KEY_ID=<same-minio-access-key>
OBJECT_STORE_S3_SECRET_ACCESS_KEY=<same-minio-secret-key>

FLOWCORDIA_REGISTRY_USERNAME=flowcordia
FLOWCORDIA_REGISTRY_PASSWORD=<random-registry-password>
FLOWCORDIA_REGISTRY_HTTP_SECRET=<random-registry-http-secret>
DEPLOY_REGISTRY_USERNAME=flowcordia
DEPLOY_REGISTRY_PASSWORD=<same-registry-password>

GITHUB_APP_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n<replace-with-pem-body>\n-----END PRIVATE KEY-----
GITHUB_APP_WEBHOOK_SECRET=<at-least-32-random-characters>
FLOWCORDIA_PROPOSAL_EVENT_SECRET=<at-least-32-random-characters>
RESEND_API_KEY=<replace-with-resend-api-key>
