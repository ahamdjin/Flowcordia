{
  "name": "@flowcordia/runtime",
  "version": "0.1.0",
  "description": "Deterministic Flowcordia compiler, safe preview runner, and Trigger.dev runtime adapter",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "engines": {
    "node": ">=20.20.2"
  },
  "exports": {
    ".": {
      "@triggerdotdev/source": "./src/index.ts",
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "dev": "tsc --watch -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.src.json --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@flowcordia/workflow": "workspace:*",
    "cron-parser": "4.9.0"
  },
  "devDependencies": {
    "rimraf": "6.0.1"
  }
}
