{
  "schemaVersion": "0.1",
  "id": "scheduled_code",
  "name": "Scheduled code task",
  "description": "Run reviewed repository code every morning.",
  "nodes": [
    {
      "id": "daily_schedule",
      "name": "Every morning",
      "kind": "trigger",
      "operation": "schedule.cron",
      "position": { "x": 80, "y": 140 },
      "configuration": { "cron": "0 8 * * *", "timezone": "UTC" }
    },
    {
      "id": "build_report",
      "name": "Build report",
      "kind": "code",
