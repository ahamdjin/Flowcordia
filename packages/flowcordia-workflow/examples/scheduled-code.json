      "codeReference": {
        "repository": "acme/operations",
        "path": "src/workflows/daily-report.ts",
        "exportName": "buildDailyReport",
        "commit": "8e919d22a429292faf53fa2e76b47e6aefb35a8d"
      },
      "runtime": {
        "machine": "small-1x",
        "maxDurationSeconds": 300
      }
    }
  ],
  "edges": [
    {
      "id": "schedule_to_report",
      "source": "daily_schedule",
      "target": "build_report"
    }
  ],
  "metadata": {
    "sourceRepository": "acme/operations",
    "sourcePath": ".flowcordia/workflows/scheduled-code.json"
