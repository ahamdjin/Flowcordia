{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flowcordia.dev/schemas/node-package-0.1.json",
  "title": "Flowcordia node package manifest 0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "package", "publisher", "operations"],
  "properties": {
    "schemaVersion": { "const": "0.1" },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "name"],
      "properties": {
        "id": {
          "type": "string",
          "maxLength": 128,
          "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)+$"
        },
        "version": {
          "type": "string",
          "maxLength": 80,
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$"
        },
        "name": { "type": "string", "minLength": 1, "maxLength": 120 },
        "description": { "type": "string", "minLength": 1, "maxLength": 500 }
      }
    },
    "publisher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "maxLength": 64,
          "pattern": "^[a-z][a-z0-9_-]{1,63}$"
        },
        "name": { "type": "string", "minLength": 1, "maxLength": 120 },
        "url": { "type": "string", "minLength": 1, "maxLength": 500 }
      }
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": { "$ref": "#/$defs/operation" }
    }
  },
  "$defs": {
    "objectSchema": {
      "type": "object"
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "catalogVersion",
        "label",
        "description",
        "category",
        "kind",
        "operation",
        "runtime",
        "configurationSchema",
        "inputSchema",
        "outputSchema",
        "capabilities"
      ],
      "properties": {
        "id": {
          "type": "string",
          "maxLength": 128,
          "pattern": "^[a-z][a-z0-9_-]*(?:\\.[a-z0-9_-]+)+$"
        },
        "catalogVersion": { "type": "integer", "minimum": 1, "maximum": 1000000 },
        "label": { "type": "string", "minLength": 1, "maxLength": 120 },
        "description": { "type": "string", "minLength": 1, "maxLength": 500 },
        "category": { "enum": ["trigger", "action", "logic", "output"] },
        "kind": { "enum": ["trigger", "action", "control", "output"] },
        "operation": {
          "type": "string",
          "maxLength": 160,
          "pattern": "^[a-z][a-z0-9_-]*(?:\\.[a-z0-9_-]+)+$"
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "path", "exportName"],
          "properties": {
            "type": { "const": "repository" },
            "path": { "type": "string", "minLength": 1, "maxLength": 512 },
            "exportName": { "type": "string", "minLength": 1, "maxLength": 128 }
          }
        },
        "configurationSchema": { "$ref": "#/$defs/objectSchema" },
        "inputSchema": { "$ref": "#/$defs/objectSchema" },
        "outputSchema": { "$ref": "#/$defs/objectSchema" },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "uniqueItems": true,
          "items": {
            "enum": [
              "structural_preview",
              "live_execution",
              "credential_references",
              "governed_code_generation",
              "production_binding",
              "network_access"
            ]
          }
        },
        "credentials": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "label", "type", "scope"],
            "properties": {
              "id": {
                "type": "string",
                "maxLength": 64,
                "pattern": "^[a-z][a-z0-9-]{1,63}$"
              },
              "label": { "type": "string", "minLength": 1, "maxLength": 120 },
              "type": { "enum": ["api_key", "oauth2", "basic", "custom_headers"] },
              "scope": { "const": "project_environment" }
            }
          }
        },
        "network": {
          "type": "object",
          "additionalProperties": false,
          "required": ["origins"],
          "properties": {
            "origins": {
              "type": "array",
              "minItems": 1,
              "maxItems": 32,
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1, "maxLength": 2048 }
            }
          }
        }
      }
    }
  }
}
