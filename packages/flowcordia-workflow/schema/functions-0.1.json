{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flowcordia.dev/schemas/functions-0.1.json",
  "title": "Flowcordia function catalog 0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "functions"],
  "properties": {
    "schemaVersion": {
      "const": "0.1"
    },
    "functions": {
      "type": "array",
      "maxItems": 500,
      "items": {
        "$ref": "#/$defs/function"
      }
    }
  },
  "$defs": {
    "schemaNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["object", "array", "string", "number", "integer", "boolean", "null"]
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "enum": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100
        },
        "const": {},
        "properties": {
          "type": "object",
          "maxProperties": 100,
          "additionalProperties": {
            "$ref": "#/$defs/schemaNode"
          }
        },
        "required": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        },
        "additionalProperties": {
          "type": "boolean"
        },
        "items": {
          "$ref": "#/$defs/schemaNode"
        },
        "minItems": {
          "type": "integer",
          "minimum": 0
        },
        "maxItems": {
          "type": "integer",
          "minimum": 0
        },
        "minLength": {
          "type": "integer",
          "minimum": 0
        },
        "maxLength": {
          "type": "integer",
          "minimum": 0
        },
        "minimum": {
          "type": "number"
        },
        "maximum": {
          "type": "number"
        }
      }
    },
    "jsonObjectSchema": {
      "allOf": [
        {
          "$ref": "#/$defs/schemaNode"
        },
        {
          "properties": {
            "type": {
              "const": "object"
            }
          }
        }
      ]
    },
    "codeReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "exportName"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "exportName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    },
    "function": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "codeReference", "inputSchema", "outputSchema"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]{1,127}$"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "codeReference": {
          "$ref": "#/$defs/codeReference"
        },
        "inputSchema": {
          "$ref": "#/$defs/jsonObjectSchema"
        },
        "outputSchema": {
          "$ref": "#/$defs/jsonObjectSchema"
        },
        "fixtures": {
          "type": "array",
          "maxItems": 50,
          "items": {
            "$ref": "#/$defs/fixture"
          }
        }
      }
    },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "input", "mockOutput"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]{1,127}$"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "input": {
          "type": "object"
        },
        "mockOutput": {
          "type": "object"
        }
      }
    }
  }
}
