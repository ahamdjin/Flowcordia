{
  "name": "@flowcordia/workflow",
  "version": "0.1.0",
  "description": "Canonical workflow contract shared by Flowcordia Studio, GitHub, and runtime adapters",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "engines": {
    "node": ">=18.20.0"
  },
  "exports": {
    ".": {
      "@triggerdotdev/source": "./src/index.ts",
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./schema/0.1": "./schema/0.1.json",
    "./schema/functions-0.1": "./schema/functions-0.1.json",
    "./schema/node-package-0.1": "./schema/node-package-0.1.json"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "dev": "tsc --watch -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.src.json --noEmit",
    "test": "vitest"
  },
  "devDependencies": {
    "rimraf": "6.0.1"
  }
}
